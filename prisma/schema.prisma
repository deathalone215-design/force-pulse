// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Tournament {
  id         String               @id @default(uuid())
  name       String
  logoUrl    String?              // Base64 logo or Supabase URL
  startDate  DateTime
  createdAt  DateTime             @default(now())
  categories TournamentCategory[]
}

model TournamentCategory {
  id               String     @id @default(uuid())
  name             String     // e.g. U15, OPEN
  sport            String     @default("FOOTBALL") // FOOTBALL | CRICKET | VOLLEYBALL | BADMINTON | PICKLEBALL
  oversPerInnings  Int?       // Limited overs for cricket categories
  scheduleFormat   String     @default("ROUND_ROBIN") // ROUND_ROBIN | LEAGUE | KNOCKOUT | SWISS
  tournamentId     String
  tournament       Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams            Team[]
  rounds           Round[]

  @@unique([tournamentId, name, sport])
}

model Team {
  id         String              @id @default(uuid())
  name       String
  logoUrl    String?             // Base64 logo data URL
  categoryId String
  category   TournamentCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  players    Player[]
  homeMatches Match[]            @relation("HomeTeam")
  awayMatches Match[]            @relation("AwayTeam")
}

model Player {
  id           String       @id @default(uuid())
  name         String
  shirtNumber  Int
  logoUrl      String?      // Base64 player photo / logo
  teamId       String
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchEvents  MatchEvent[]
}

model Round {
  id         String             @id @default(uuid())
  number     Int                // Round index (1, 2, etc.)
  categoryId String
  category   TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matches    Match[]
}

model Match {
  id              String        @id @default(uuid())
  roundId         String
  round           Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamAId         String
  teamA           Team          @relation("HomeTeam", fields: [teamAId], references: [id], onDelete: Cascade)
  teamBId         String
  teamB           Team          @relation("AwayTeam", fields: [teamBId], references: [id], onDelete: Cascade)
  scoreA          Int           @default(0) // Football goals / cricket runs / sets won
  scoreB          Int           @default(0)
  status          String        @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED
  kickoffAt       DateTime?     // Football clock start (set when match goes LIVE)
  clockPausedAt   DateTime?     // When set, match clock is frozen (injury / interruption)
  pausedSeconds   Int           @default(0) // Total completed pause time subtracted from clock
  stoppageMinutes Int           @default(0) // Announced stoppage / added time (+N')
  penaltyScoreA   Int           @default(0) // Penalty shootout scored (team A)
  penaltyScoreB   Int           @default(0) // Penalty shootout scored (team B)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  version         Int           @default(0) // CAS / optimistic concurrency for scorers
  scoreLockId     String?       // Active scorer device token (optional exclusive lock)
  scoreLockedAt   DateTime?     // When the score lock was claimed
  // Cricket-specific
  oversLimit      Int?
  currentInnings  Int           @default(1)
  battingTeamId   String?
  strikerId       String?
  nonStrikerId    String?
  bowlerId        String?
  wicketsA        Int           @default(0)
  wicketsB        Int           @default(0)
  ballsFacedA     Int           @default(0) // Legal balls only
  ballsFacedB     Int           @default(0)
  inningsComplete Int           @default(0) // 0 = none, 1 = first done, 2 = both done
  // Set-based sports (Volleyball, Badminton, Pickleball)
  currentSet      Int           @default(1)
  servingTeamId   String?
  events          MatchEvent[]
  cricketBalls    CricketBall[]
  matchSets       MatchSet[]
}

model MatchSet {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber Int
  scoreA    Int      @default(0)
  scoreB    Int      @default(0)
  winnerId  String?  // teamAId, teamBId, or null if in progress
  createdAt DateTime @default(now())
}

model MatchEvent {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId    String?  // The team associated with the event
  playerId  String?  // The player who scored/received card
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type      String   // GOAL, OWN_GOAL, YELLOW_CARD, RED_CARD, SUB
  minute    Int?     // Minute of match
  createdAt DateTime @default(now())
}

model CricketBall {
  id                String   @id @default(uuid())
  matchId           String
  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  innings           Int      // 1 or 2
  overNumber        Int      // 0-based over index
  ballInOver        Int      // 1–6 for legal balls; 0 for extras that don't count
  battingTeamId     String
  strikerId         String?
  nonStrikerId      String?
  bowlerId          String?
  runsOffBat        Int      @default(0)
  extras            Int      @default(0)
  extraType         String?  // WD | NB | BYE | LB | null
  isWicket          Boolean  @default(false)
  dismissalType     String?  // BOWLED | CAUGHT | LBW | RUN_OUT | STUMPED | OTHER
  dismissedPlayerId String?
  runsTotal         Int      @default(0)
  isLegal           Boolean  @default(true)
  createdAt         DateTime @default(now())
}
