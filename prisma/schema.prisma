// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Tournament {
  id               String               @id @default(uuid())
  name             String
  logoUrl          String?              // Base64 logo data URL
  sport            String               @default("FOOTBALL") // FOOTBALL | CRICKET
  oversPerInnings  Int?                 // Limited overs for cricket (e.g. 20)
  startDate        DateTime
  createdAt        DateTime             @default(now())
  categories       TournamentCategory[]
}

model TournamentCategory {
  id           String     @id @default(uuid())
  name         String     // e.g. U15, OPEN
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams        Team[]
  rounds       Round[]
}

model Team {
  id         String              @id @default(uuid())
  name       String
  logoUrl    String?             // Base64 logo data URL
  categoryId String
  category   TournamentCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  players    Player[]
  homeMatches Match[]            @relation("HomeTeam")
  awayMatches Match[]            @relation("AwayTeam")
}

model Player {
  id           String       @id @default(uuid())
  name         String
  shirtNumber  Int
  logoUrl      String?      // Base64 player photo / logo
  teamId       String
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchEvents  MatchEvent[]
}

model Round {
  id         String             @id @default(uuid())
  number     Int                // Round index (1, 2, etc.)
  categoryId String
  category   TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matches    Match[]
}

model Match {
  id              String        @id @default(uuid())
  roundId         String
  round           Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamAId         String
  teamA           Team          @relation("HomeTeam", fields: [teamAId], references: [id], onDelete: Cascade)
  teamBId         String
  teamB           Team          @relation("AwayTeam", fields: [teamBId], references: [id], onDelete: Cascade)
  scoreA          Int           @default(0) // Football goals / cricket runs
  scoreB          Int           @default(0)
  status          String        @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED
  // Cricket-specific
  oversLimit      Int?
  currentInnings  Int           @default(1)
  battingTeamId   String?
  strikerId       String?
  nonStrikerId    String?
  bowlerId        String?
  wicketsA        Int           @default(0)
  wicketsB        Int           @default(0)
  ballsFacedA     Int           @default(0) // Legal balls only
  ballsFacedB     Int           @default(0)
  inningsComplete Int           @default(0) // 0 = none, 1 = first done, 2 = both done
  events          MatchEvent[]
  cricketBalls    CricketBall[]
}

model MatchEvent {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId    String?  // The team associated with the event
  playerId  String?  // The player who scored/received card
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type      String   // GOAL, OWN_GOAL, YELLOW_CARD, RED_CARD, SUB
  minute    Int?     // Minute of match
  createdAt DateTime @default(now())
}

model CricketBall {
  id                String   @id @default(uuid())
  matchId           String
  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  innings           Int      // 1 or 2
  overNumber        Int      // 0-based over index
  ballInOver        Int      // 1–6 for legal balls; 0 for extras that don't count
  battingTeamId     String
  strikerId         String?
  nonStrikerId      String?
  bowlerId          String?
  runsOffBat        Int      @default(0)
  extras            Int      @default(0)
  extraType         String?  // WD | NB | BYE | LB | null
  isWicket          Boolean  @default(false)
  dismissalType     String?  // BOWLED | CAUGHT | LBW | RUN_OUT | STUMPED | OTHER
  dismissedPlayerId String?
  runsTotal         Int      @default(0)
  isLegal           Boolean  @default(true)
  createdAt         DateTime @default(now())
}
